# Example backend environment variables.
# Export these (or use your runtime's secret manager) before starting the app.
# Do NOT commit a file containing real secrets.

# Database connection. Either set the full JDBC URL...
DB_URL=jdbc:postgresql://localhost:5432/parcelplus?sslmode=disable
# ...or leave DB_URL unset and supply the parts (used by the hosted setup):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=parcelplus
# DB_SSLMODE=disable        # use "require" for managed/cloud Postgres
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Hibernate schema management: validate | update | none (prefer validate + migrations in prod)
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# HikariCP pool size
DB_POOL_SIZE=5

# Comma-separated list of allowed CORS origins (the frontend URL(s))
CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT signing secret (>= 32 chars). Generate a long random value for production.
JWT_SECRET=please-generate-a-long-random-secret-at-least-32-chars
# Token lifetime in milliseconds (default 24h)
JWT_EXPIRATION_MS=86400000
