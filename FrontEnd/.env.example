# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# Google Maps JavaScript API key (restrict it by HTTP referrer in Google Cloud Console)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Base URL of the backend REST API
REACT_APP_API_BASE_URL=http://localhost:8080/api

# Base URL of the backend WebSocket endpoint
REACT_APP_WS_BASE_URL=ws://localhost:8080
